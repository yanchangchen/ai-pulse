# AI Pulse Environment Configuration

# Ollama Configuration (no API key needed, runs locally)

# Model to use (must be pulled in Ollama)
# Default: qwen3-coder:30b
# To pull: ollama pull qwen3-coder:30b
OLLAMA_MODEL=qwen3-coder:30b

# Optional: NewsAPI Key for additional news coverage
# Get from: https://newsapi.org/
NEWSAPI_KEY=your-newsapi-key-here
